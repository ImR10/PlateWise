{
  "name": "platewise",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "user:dev": "pnpm --filter @platewise/user dev",
    "user:build": "pnpm --filter @platewise/user build",
    "user:test": "pnpm --filter @platewise/user test",
    "user:lint": "pnpm --filter @platewise/user lint",
    "user:format": "pnpm --filter @platewise/user format",
    "user:format:check": "pnpm --filter @platewise/user format:check",
    "admin:dev": "pnpm --filter @platewise/admin dev",
    "admin:build": "pnpm --filter @platewise/admin build",
    "admin:test": "pnpm --filter @platewise/admin test",
    "admin:lint": "pnpm --filter @platewise/admin lint",
    "admin:format": "pnpm --filter @platewise/admin format",
    "admin:format:check": "pnpm --filter @platewise/admin format:check",
    "admin:typecheck": "pnpm --filter @platewise/admin typecheck"
  }
}
